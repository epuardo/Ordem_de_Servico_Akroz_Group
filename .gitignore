# -----------------------------------------------
# 1. Ignorar dependências do Composer (CRÍTICO!)
# -----------------------------------------------
# A pasta 'vendor' deve ser reconstruída no servidor usando 'composer install'.
/vendor/

# -----------------------------------------------
# 2. Ignorar uploads de usuário e arquivos temporários
# -----------------------------------------------
# NUNCA versionar arquivos carregados por usuários (NF, imagens de equipamento).
/uploads/
*.tmp
*.log
*.bak

# -----------------------------------------------
# 3. Ignorar configurações de ambiente e segurança
# -----------------------------------------------
# Arquivo .env contém senhas e chaves SMTP. Ele DEVE ser ignorado.
.env

# -----------------------------------------------
# 4. Ignorar configurações IDE/Sistema
# -----------------------------------------------
# Configurações do ambiente de desenvolvimento (VS Code, PHPStorm, etc.)
.idea/
.vscode/

# Ignorar o diretório de dados do Mac OS X (se você também usar Mac)
.DS_Store

# Ignorar thumbs.db e desktop.ini no Windows
Thumbs.db
desktop.ini
